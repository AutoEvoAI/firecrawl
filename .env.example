# FIRE_PDF_PERCENT=10

# Fire PDF base URL
# Required for: Using Fire PDF service
# Optional: false
# FIRE_PDF_BASE_URL=

# Fire PDF API key
# Required for: Authenticating with Fire PDF service
# Optional: false
# FIRE_PDF_API_KEY=

# PDF Rust extraction enable flag
# Required for: Enabling PDF Rust extraction (pdf-inspector)
# Optional: false
# PDF_RUST_EXTRACT_ENABLE=

# PDF shadow comparison enable flag
# Required for: Enabling PDF shadow comparison
# Optional: false
# PDF_SHADOW_COMPARISON_ENABLE=

## === RunPod Configuration ===
# RunPod MU API key
# Required for: Using RunPod for PDF processing
# Optional: false
# RUNPOD_MU_API_KEY=

# RunPod MU pod ID
# Required for: Using RunPod for PDF processing
# Optional: false
# RUNPOD_MU_POD_ID=

