# Required for: Autumn request tracking experiment
# Optional: false
# AUTUMN_REQUEST_TRACK_EXPERIMENT_PERCENT=100

# Resend API key (for transactional emails)
# Required for: Sending emails via Resend
# Optional: false
# RESEND_API_KEY=

# Preview token
# Required for: Preview features
# Optional: false
# PREVIEW_TOKEN=

# LlamaParse API key
# Required for: Using LlamaParse for PDF parsing
# Optional: false
# LLAMAPARSE_API_KEY=

## === Queue Management ===
# This key lets you access the queue admin panel. Change this if your deployment is publicly accessible.
# Required for: Accessing Bull queue admin panel
# Optional: true (but recommended to change from default)
# BULL_AUTH_KEY=CHANGEME
