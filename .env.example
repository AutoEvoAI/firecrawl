# ===== Required ENVS ======
PORT=3002
HOST=0.0.0.0

# Note: PORT is used by both the main API server and worker liveness check endpoint

# To turn on DB authentication, you need to set up Supabase.
USE_DB_AUTHENTICATION=false

# ===== Optional ENVS ======

## === Application Configuration ===
# Environment identifier (development, staging, production)
# Default: undefined
# ENV=

# Production mode flag
# Default: false
# IS_PRODUCTION=

# Kubernetes environment flag
# Default: false
# IS_KUBERNETES=

# Firecrawl app service host (for internal service communication)
# Default: firecrawl-app-service
# FIRECRAWL_APP_HOST=

# Firecrawl app service port
# Default: 3002
# FIRECRAWL_APP_PORT=

# Firecrawl app service scheme (http or https)
# Default: http
# FIRECRAWL_APP_SCHEME=

# Logging level (NONE, ERROR, WARN, INFO, DEBUG, TRACE)
# Default: INFO
# LOGGING_LEVEL=INFO

# Express trust proxy setting (for running behind reverse proxies)
# Default: undefined
# EXPRESS_TRUST_PROXY=

## === AI features (JSON format on scrape, /extract API) ===
# Provide your OpenAI API key here to enable AI features
# Required for: AI-powered extraction, classification, and analysis
# Optional: false (unless using AI features)
# OPENAI_API_KEY=

# OpenAI-compatible API base URL (for using alternative providers)
# Required for: Using non-OpenAI OpenAI-compatible APIs
# Optional: false
# OPENAI_BASE_URL=https://example.com/v1

# OpenRouter API key (for using OpenRouter as AI provider)
# Required for: Using OpenRouter AI models
# Optional: false
# OPENROUTER_API_KEY=

# Experimental: Use Ollama for local AI models
# Required for: Running local AI models via Ollama
# Optional: false
# OLLAMA_BASE_URL=http://localhost:11434/api
# MODEL_NAME=deepseek-r1:7b
# MODEL_EMBEDDING_NAME=nomic-embed-text

# Google Vertex AI credentials (JSON format)
# Required for: Using Google Vertex AI models
# Optional: false
# VERTEX_CREDENTIALS=

## === Proxy Configuration ===
# PROXY_SERVER can be a full URL (e.g. http://0.1.2.3:1234) or just an IP and port combo (e.g. 0.1.2.3:1234)
# Do not uncomment PROXY_USERNAME and PROXY_PASSWORD if your proxy is unauthenticated
# Required for: Routing requests through proxy servers
# Optional: false
# PROXY_SERVER=
# PROXY_USERNAME=
# PROXY_PASSWORD=
# PROXY_STEALTH_SERVER=
# PROXY_STEALTH_USERNAME=
# PROXY_STEALTH_PASSWORD=

# OpenSandbox URL (for using OpenSandbox as proxy engine)
# Required for: Using OpenSandbox for advanced proxy capabilities
# Optional: false
# OPENSANDBOX_URL=
# OPENSANDBOX_API_KEY=

## === Search API Configuration ===
# By default, the /search API will use Google search.

# SearXNG server endpoint with JSON format enabled
# Required for: Using SearXNG instead of direct Google search
# Optional: false
# SEARXNG_ENDPOINT=http://your.searxng.server
# SEARXNG_ENGINES=
# SEARXNG_CATEGORIES=

# Search service URL (custom search service)
# Required for: Using custom search service
# Optional: false
# SEARCH_SERVICE_URL=

# Search service API secret
# Required for: Authenticating with custom search service
# Optional: false
# SEARCH_SERVICE_API_SECRET=

# Search preview token (for previewing search results without credits)
# Required for: Testing search API without consuming credits
# Optional: false
# SEARCH_PREVIEW_TOKEN=

# Enable search index feature
# Required for: Enabling search indexing functionality
# Optional: false
# ENABLE_SEARCH_INDEX=

# Search index sample rate (0.0-1.0)
# Default: 0.1 (10%)
# Required for: Controlling what percentage of searches are indexed
# Optional: false
# SEARCH_INDEX_SAMPLE_RATE=0.1

## === AI Search Cache ===
# Enable AI search cache
# Default: true
# Required for: Enabling search result caching
# Optional: false
# AI_SEARCH_CACHE_ENABLED=true

# Cache TTL for non-AI mode in seconds
# Default: 3600 (1 hour)
# Required for: Controlling cache duration for non-AI searches
# Optional: false
# AI_SEARCH_CACHE_TTL_NON_AI=3600

# Cache TTL for AI mode in seconds
# Default: 300 (5 minutes)
# Required for: Controlling cache duration for AI-expanded searches
# Optional: false
# AI_SEARCH_CACHE_TTL_AI=300

# Cache TTL for full AI mode in seconds
# Default: 180 (3 minutes)
# Required for: Controlling cache duration for full AI searches
# Optional: false
# AI_SEARCH_CACHE_TTL_FULL=180

## === AI Search Dispatcher ===
# Default search engines (comma-separated)
# Required for: Configuring default search engines
# Optional: false
# AI_SEARCH_DEFAULT_ENGINES=google,bing,duckduckgo

# Default search categories (comma-separated)
# Required for: Configuring default search categories
# Optional: false
# AI_SEARCH_DEFAULT_CATEGORIES=general

# Enable time range filtering
# Default: true
# Required for: Enabling time-based search filters
# Optional: false
# AI_SEARCH_TIME_RANGE_ENABLED=true

# Safe search level (none, moderate, strict)
# Default: moderate
# Required for: Controlling content filtering
# Optional: false
# AI_SEARCH_SAFESEARCH=moderate

## === AI Search Aggregator ===
# Maximum results for reranker input
# Default: 50
# Required for: Controlling how many results are sent to reranker
# Optional: false
# AI_SEARCH_MAX_RESULTS_FOR_RERANK=50

# Enable result deduplication
# Default: true
# Required for: Enabling duplicate URL removal
# Optional: false
# AI_SEARCH_DEDUP_ENABLED=true

## === AI Search Preprocessor ===
# LLM model for query expansion and intent classification
# Default: gpt-4o-mini
# Required for: AI-powered query preprocessing
# Optional: false
# AI_SEARCH_LLM_MODEL=gpt-4o-mini

## === AI Search Reranker ===
# Embedding model for coarse reranking
# Default: bge-reranker-v2-m3
# Required for: Embedding-based similarity calculation
# Optional: false
# AI_SEARCH_EMBEDDING_MODEL=bge-reranker-v2-m3

# API key for embedding service (e.g., Jina AI, OpenAI, etc.)
# Required for: Authentication with embedding provider
# Optional: true (falls back to OPENAI_API_KEY if not set)
# AI_SEARCH_EMBEDDING_API_KEY=

# Base URL for embedding service
# Required for: Custom embedding endpoint (e.g., https://api.jina.ai/v1/embeddings)
# Optional: true (falls back to provider default if not set)
# AI_SEARCH_EMBEDDING_BASE_URL=

# Top K results after embedding-based reranking
# Default: 20
# Required for: Controlling coarse reranking output size
# Optional: false
# AI_SEARCH_EMBEDDING_TOP_K=20

# Top K results after LLM-based reranking
# Default: 10
# Required for: Controlling fine reranking output size
# Optional: false
# AI_SEARCH_LLM_TOP_K=10

## === Supabase Configuration ===
# Main Supabase Configuration
# Required for: Database authentication, user management, and advanced logging
# Optional: false (unless USE_DB_AUTHENTICATION=true)
# SUPABASE_ANON_TOKEN=
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_TOKEN=
# SUPABASE_REPLICA_URL=https://xxx.supabase.co

# Supabase Index Configuration (optional, for search indexing features)
# Note: Supabase JS client does not support specifying schemas via URL parameters
# Configure schemas through Supabase Dashboard or SQL commands
# Required for: Search indexing features
# Optional: false
# INDEX_SUPABASE_URL=https://xxx.supabase.co
# INDEX_SUPABASE_SERVICE_TOKEN=
# SEARCH_INDEX_SUPABASE_URL=

# Supabase PostgreSQL Connection (for database initialization)
# Required for: Database initialization and direct PostgreSQL access
# Optional: false
# SUPABASE_POSTGRES_HOST=aws-1-ap-northeast-1.pooler.supabase.com
# SUPABASE_POSTGRES_USER=postgres.xxx
# SUPABASE_POSTGRES_PASSWORD=your_password

## === Database Configuration ===
# PostgreSQL host
# Default: localhost
# Required for: Connecting to PostgreSQL database
# Optional: false (uses default if not set)
# POSTGRES_HOST=

# PostgreSQL port
# Default: 5432
# Required for: Connecting to PostgreSQL database
# Optional: false (uses default if not set)
# POSTGRES_PORT=

# PostgreSQL database name
# Default: postgres
# Required for: Connecting to PostgreSQL database
# Optional: false (uses default if not set)
# POSTGRES_DB=

# PostgreSQL username
# Default: postgres
# Required for: Connecting to PostgreSQL database
# Optional: false (uses default if not set)
# POSTGRES_USER=

# PostgreSQL password
# Default: postgres
# Required for: Connecting to PostgreSQL database
# Optional: false (uses default if not set)
# POSTGRES_PASSWORD=

# Redis connection URL
# Required for: Queue management, caching, and rate limiting
# Optional: false (auto-configured by docker-compose)
# REDIS_URL=redis://redis:6379

# Redis eviction URL (for cache eviction)
# Required for: Advanced cache management
# Optional: false
# REDIS_EVICT_URL=

# Redis rate limit URL
# Required for: Rate limiting functionality
# Optional: false (auto-configured by docker-compose)
# REDIS_RATE_LIMIT_URL=redis://redis:6379

# NUQ database URL (Nuque database connection)
# Required for: Nuque queue system
# Optional: false
# NUQ_DATABASE_URL=

# NUQ database listen URL
# Required for: Nuque queue system
# Optional: false
# NUQ_DATABASE_URL_LISTEN=

# NUQ RabbitMQ URL
# Required for: Nuque queue system
# Optional: false
# NUQ_RABBITMQ_URL=

## === Google Cloud Storage Configuration ===
# GCS bucket name (for storing scrape results)
# Required for: Storing scrape results in Google Cloud Storage
# Optional: false
# GCS_BUCKET_NAME=

# GCS credentials (JSON format)
# Required for: Authenticating with Google Cloud Storage
# Optional: false
# GCS_CREDENTIALS=

# GCS Fire Engine bucket name
# Required for: Fire Engine results storage
# Optional: false
# GCS_FIRE_ENGINE_BUCKET_NAME=

# GCS Index bucket name
# Required for: Search index storage
# Optional: false
# GCS_INDEX_BUCKET_NAME=

# GCS Media bucket name
# Required for: Media file storage
# Optional: false
# GCS_MEDIA_BUCKET_NAME=

## === ClickHouse Configuration ===
# ClickHouse analytics URL
# Required for: Search analytics and reporting
# Optional: false
# CLICKHOUSE_ANALYTICS_URL=

# ClickHouse analytics database name
# Required for: Search analytics and reporting
# Optional: false
# CLICKHOUSE_ANALYTICS_DATABASE=

## === Fire Engine Configuration ===
# Fire Engine beta URL
# Required for: Using Fire Engine (advanced scraping engine)
# Optional: false
# FIRE_ENGINE_BETA_URL=

# Fire Engine staging URL
# Required for: Using Fire Engine staging environment
# Optional: false
# FIRE_ENGINE_STAGING_URL=

# Fire Engine A/B testing URL
# Required for: A/B testing Fire Engine
# Optional: false
# FIRE_ENGINE_AB_URL=

# Fire Engine A/B testing rate (0.0-1.0)
# Required for: A/B testing Fire Engine
# Optional: false
# FIRE_ENGINE_AB_RATE=

# Fire Engine A/B testing mode (mirror or split)
# Default: mirror
# Required for: A/B testing Fire Engine
# Optional: false
# FIRE_ENGINE_AB_MODE=mirror

## === Indexer Configuration ===
# Indexer RabbitMQ URL
# Required for: Indexer queue system
# Optional: false
# INDEXER_RABBITMQ_URL=

# Indexer traffic share (0.0-1.0)
# Default: 0.0
# Required for: Controlling traffic to indexer
# Optional: false
# INDEXER_TRAFFIC_SHARE=0.0

## === ScrapeURL Configuration ===
# ScrapeURL A/B testing host
# Required for: A/B testing ScrapeURL
# Optional: false
# SCRAPEURL_AB_HOST=

# ScrapeURL A/B testing rate (0.0-1.0)
# Required for: A/B testing ScrapeURL
# Optional: false
# SCRAPEURL_AB_RATE=

# ScrapeURL A/B testing extend max age
# Required for: A/B testing ScrapeURL cache behavior
# Optional: false
# SCRAPEURL_AB_EXTEND_MAXAGE=

# ScrapeURL engine waterfall delay in milliseconds
# Default: 0
# Required for: Controlling delay between engine fallbacks
# Optional: false
# SCRAPEURL_ENGINE_WATERFALL_DELAY_MS=0

## === Scrape Retry Limits ===
# Maximum scrape retry attempts
# Default: 6
# Required for: Controlling scrape retry behavior
# Optional: false
# SCRAPE_MAX_ATTEMPTS=6

# Maximum feature toggle attempts
# Default: 3
# Required for: Controlling feature toggle retry behavior
# Optional: false
# SCRAPE_MAX_FEATURE_TOGGLES=3

# Maximum feature removal attempts
# Default: 3
# Required for: Controlling feature removal retry behavior
# Optional: false
# SCRAPE_MAX_FEATURE_REMOVALS=3

# Maximum PDF prefetch attempts
# Default: 2
# Required for: Controlling PDF prefetch behavior
# Optional: false
# SCRAPE_MAX_PDF_PREFETCHES=2

# Maximum document prefetch attempts
# Default: 2
# Required for: Controlling document prefetch behavior
# Optional: false
# SCRAPE_MAX_DOCUMENT_PREFETCHES=2

## === Worker Configuration ===
# Worker port
# Default: 3005
# Required for: Worker service communication
# Optional: false
# WORKER_PORT=3005

# NUQ worker port
# Default: 3000
# Required for: NUQ worker service
# Optional: false
# NUQ_WORKER_PORT=3000

# NUQ worker start port
# Default: 3006
# Required for: NUQ worker service
# Optional: false
# NUQ_WORKER_START_PORT=3006

# NUQ worker count
# Default: 5
# Required for: Number of NUQ worker processes
# Optional: false
# NUQ_WORKER_COUNT=5

# NUQ prefetch worker port
# Default: 3011
# Required for: NUQ prefetch worker service
# Optional: false
# NUQ_PREFETCH_WORKER_PORT=3011

# NUQ reconciler worker port
# Default: 3012
# Required for: NUQ reconciler worker service
# Optional: false
# NUQ_RECONCILER_WORKER_PORT=3012

# NUQ wait mode
# Required for: NUQ worker wait behavior
# Optional: false
# NUQ_WAIT_MODE=

# NUQ prefetch worker heartbeat URL
# Required for: NUQ prefetch worker health checks
# Optional: false
# NUQ_PREFETCH_WORKER_HEARTBEAT_URL=

## === Harness Configuration ===
# Harness startup timeout in milliseconds
# Default: 60000
# Required for: Controlling harness startup timeout
# Optional: false
# HARNESS_STARTUP_TIMEOUT_MS=60000

## === Job & Lock Management ===
# Job lock extend interval in milliseconds
# Default: 10000
# Required for: Job lock management
# Optional: false
# JOB_LOCK_EXTEND_INTERVAL=10000

# Job lock extension time in milliseconds
# Default: 60000
# Required for: Job lock management
# Optional: false
# JOB_LOCK_EXTENSION_TIME=60000

# Worker lock duration in milliseconds
# Default: 60000
# Required for: Worker lock management
# Optional: false
# WORKER_LOCK_DURATION=60000

# Worker stalled check interval in milliseconds
# Default: 30000
# Required for: Worker health monitoring
# Optional: false
# WORKER_STALLED_CHECK_INTERVAL=30000

# Connection monitor interval
# Default: 10
# Required for: Connection monitoring
# Optional: false
# CONNECTION_MONITOR_INTERVAL=10

# Cannot accept connection interval in milliseconds
# Default: 2000
# Required for: Connection rate limiting
# Optional: false
# CANT_ACCEPT_CONNECTION_INTERVAL=2000

## === External Services ===
# Playwright microservice URL
# Required for: Using Playwright for JavaScript rendering
# Optional: false (auto-configured by docker-compose)
# PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape

# HTML to Markdown service URL
# Required for: Using external HTML to Markdown conversion service
# Optional: false
# HTML_TO_MARKDOWN_SERVICE_URL=

# Smart scrape API URL
# Required for: Using smart scrape service
# Optional: false
# SMART_SCRAPE_API_URL=

