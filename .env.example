# Fire PDF enable flag
# Required for: Enabling Fire PDF (replaces MinerU)
# Optional: false
# FIRE_PDF_ENABLE=

# Fire PDF percent (0-100)
# Default: 10
# Required for: Controlling Fire PDF traffic percentage
