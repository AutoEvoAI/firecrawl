# SLACK_ADMIN_WEBHOOK_URL=

# Disable webhook delivery
# Required for: Disabling webhook delivery
# Optional: false
# DISABLE_WEBHOOK_DELIVERY=

# Allow local webhooks
# Required for: Allowing webhooks to be sent to localhost
# Optional: false
# ALLOW_LOCAL_WEBHOOKS=

# Use RabbitMQ for webhooks
# Required for: Using RabbitMQ for webhook delivery
# Optional: false
# WEBHOOK_USE_RABBITMQ=

